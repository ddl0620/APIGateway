{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/api/v1/charges",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.amount",
          "matches": "^[1-9]\\d{4,}.*"
        }
      }
    ]
  },
  "response": {
    "status": 402,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "transactionId": null,
      "status": "DECLINED",
      "message": "Payment declined: insufficient funds"
    },
    "fixedDelayMilliseconds": 800
  }
}
