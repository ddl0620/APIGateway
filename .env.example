# ============================================================
# Office MB — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# JWT signing key (Base64-encoded, min 256 bits)
JWT_SECRET=CHANGE_ME_base64_encoded_secret_key_here

# Internal API key for service-to-service authentication
INTERNAL_API_KEY=CHANGE_ME_internal_api_key_here

# MongoDB connection URIs
MONGODB_URI_USER=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/user-microservice?retryWrites=true&w=majority&tls=true
MONGODB_URI_PAYMENT=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/payment-microservice?retryWrites=true&w=majority&tls=true

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Payment gateway URL (external, not WireMock in production)
PAYMENT_GATEWAY_BASE_URL=https://api.payment-provider.com
